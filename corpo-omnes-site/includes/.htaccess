# Blocage HTTP du dossier includes/ - il ne contient que du code et des secrets (.env).
# Tu peux mettre ce .htaccess sur n'importe quel hébergement Apache (42web.io OK).

# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 (fallback)
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Sécurité supplémentaire : bloque explicitement les fichiers sensibles
<FilesMatch "^(\.env|\.env\..*|.*\.ini|.*\.log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
