# ============================================================
# Corpo Omnes - Variables d'environnement
# Copie ce fichier vers `.env` et complète avec tes vraies valeurs.
# Le `.env` n'est PAS versionné (cf. .gitignore).
# ============================================================

# ── Base de données (laisse vide pour utiliser includes/db.php) ──
# DB_HOST=localhost
# DB_NAME=corpoomneshtmlprojet
# DB_USER=root
# DB_PASS=

# ── Site ──
SITE_URL=http://localhost/CorpoOmnesHTMLClaudeCours/corpo-omnes-site
# Fuseau pour dates PHP + MySQL (liens reset / validation email)
APP_TIMEZONE=Europe/Paris

# ── Billetterie SumUp Hosted Checkout (mode TEST par défaut) ──
# Si SUMUP_API_KEY est vide, l'application bascule en mode "mock" (aucun paiement réel).
# Doc : https://developer.sumup.com/online-payments/checkouts/hosted-checkout/
#
# ⚠ Important : SumUp ne fait PAS de redirection automatique après paiement.
# Il affiche une page de succès avec un bouton "Retour au site" (si redirect_url
# est défini). Pour fiabiliser, configure un WEBHOOK dans le dashboard SumUp :
#   me.sumup.com → Settings → Developers → Webhooks
#   URL    : https://corpoomnes.42web.io/api/sumup-webhook.php
#   Events : checkout.paid, checkout.failed, checkout.canceled
# Sans webhook, le billet n'est créé que si le client revient sur la page event.
SUMUP_MODE=test
SUMUP_MERCHANT_CODE=M4RC8MDH
SUMUP_API_KEY=
# (optionnels, OAuth 2.0)
SUMUP_CLIENT_ID=
SUMUP_CLIENT_SECRET=

# ── Stripe (paiements > 25 €) ──
# Pour les billets dont le prix dépasse le seuil PAYMENT_PROVIDER_THRESHOLD,
# la plateforme bascule sur Stripe Checkout (Hosted). Sans clé, mode mock.
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
# Webhook (à configurer plus tard) :
#   URL : https://corpoomnes.42web.io/api/stripe-webhook.php
STRIPE_WEBHOOK_SECRET=

# ── Routage paiement & frais ──
# Seuil de bascule SumUp ↔ Stripe (en €) : montant ≤ seuil → SumUp, sinon Stripe.
PAYMENT_PROVIDER_THRESHOLD=25
# Frais SumUp (% du montant)
SUMUP_FEE_PERCENT=2.5
# Frais Stripe (% du montant + frais fixe en €)
STRIPE_FEE_PERCENT=1.5
STRIPE_FEE_FIXED=0.25

# ── Session PHP (cookie PHPSESSID) ──
# Si le site est dans un sous-dossier (ex. /corpo-omnes-site/), définir le path du cookie
# pour qu'il soit renvoyé sur toutes les URLs du site (sinon la session peut « sauter »).
# SESSION_COOKIE_PATH=/corpo-omnes-site/
#
# Durée de vie du cookie de session en JOURS (0 = cookie de session, supprimé à la
# fermeture du navigateur). Défaut = 30 → l'utilisateur reste connecté même après
# avoir fermé puis rouvert le navigateur. La durée est prolongée à chaque visite.
# SESSION_LIFETIME_DAYS=30

# ── Sécurité ──
# Clé secrète utilisée pour signer les tokens des QR codes.
# Régénère avec un UUID ou 32+ caractères aléatoires.
APP_SECRET=change-me-please-use-a-real-secret

# ── (Optionnel) Apple Wallet - billet .pkpass ──
# Sans certificat Pass Type ID + WWDR, le site désactive le bouton Apple Wallet.
# APPLE_WALLET_CERT_PATH=/chemin/vers/pass.p12
# APPLE_WALLET_CERT_PASS=mot_de_passe_p12
# APPLE_WALLET_TEAM_ID=XXXXXXXXXX
# APPLE_WALLET_PASS_TYPE_ID=pass.fr.corpoomnes.event
# APPLE_WALLET_WWDR_PATH=/chemin/vers/AppleWWDRCA.pem

# ── (Optionnel) Google Wallet - événement ──
# GOOGLE_WALLET_ISSUER_ID=338800000002xxxxxxx
# GOOGLE_WALLET_SERVICE_KEY_PATH=/chemin/service-account.json
# Quand l'API event-gpay.php sera implémentée : GOOGLE_WALLET_API_READY=1

# ── Mail (SMTP relay) ─────────────────────────────────────
# Si MAIL_ENABLED != 1 OU MAIL_SMTP_PASS vide, les mails sont écrits dans
# corpo-omnes-site/logs/mail.log au lieu d'être envoyés (mode dev).
MAIL_ENABLED=1
MAIL_FROM=corpoomnes@gmail.com
MAIL_FROM_NAME="Corpo Omnes Lyon"
# Mets à 1 pour avoir le détail SMTP dans logs/mail.log (utile pour debug)
MAIL_DEBUG=0
# Plafond affiché dans Admin → Mails (compteur [OK] du jour). Brevo gratuit ≈ 300/j.
MAIL_DAILY_LIMIT=300

# ════════════════════════════════════════════════════════
# CHOIX 1 - Brevo (ex-SendinBlue) - RECOMMANDÉ pour 42web.io
# ════════════════════════════════════════════════════════
# 300 mails/jour gratuits, très bonne délivrabilité. Procédure :
#   1. Crée un compte sur https://www.brevo.com (gratuit)
#   2. Onglet "Senders & IP" → "Senders" → "Add a Sender"
#        Email = corpoomnes@gmail.com  → Brevo envoie un code, clique le lien.
#   3. Onglet "SMTP & API" → "SMTP" → note ton "login" et génère une clé SMTP.
#   4. Reporte ci-dessous (MAIL_SMTP_USER = login Brevo, MAIL_SMTP_PASS = clé).
#
# Avec ce setup, le mail est :
#   - signé DKIM par Brevo (✓ délivrabilité)
#   - Return-Path réécrit par Brevo (✓ bounces gérés)
#   - From visible = corpoomnes@gmail.com (les réponses arrivent sur Gmail)
MAIL_SMTP_HOST=smtp-relay.brevo.com
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=tls
MAIL_SMTP_USER=<ton-login-brevo>
MAIL_SMTP_PASS=<ta-cle-smtp-brevo>

# ════════════════════════════════════════════════════════
# CHOIX 2 - Gmail direct (déconseillé depuis 42web.io)
# ════════════════════════════════════════════════════════
# Marche mais beaucoup de mails finissent en spam à cause de la mauvaise
# réputation IP de l'hébergeur gratuit. Procédure si tu veux essayer :
#   1. Active la 2FA sur le compte Google.
#   2. https://myaccount.google.com/apppasswords → crée un App Password.
#   3. Décommente le bloc ci-dessous et commente le bloc Brevo.
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_SECURE=tls
# MAIL_SMTP_USER=corpoomnes@gmail.com
# MAIL_SMTP_PASS=<app-password-16-caracteres>

